# PostgreSQL Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=datalake
POSTGRES_USER=postgres
POSTGRES_PASS=password

# Campus Solutions Environment
CS_ENV=test

# Data Engineering Campus Solutions Tools API Configuration
DE_CSTOOLS_ENDPOINT=https://cstools.api-nonprod.bu.edu/api/v1/queries/execute
DE_CSTOOLS_KEY=your_cstools_api_key

# SnapLogic Course API Configuration
SNAPLOGIC_COURSE_URL=https://your-snaplogic-url/course-endpoint
SNAPLOGIC_COURSE_KEY=your_snaplogic_course_api_key

# Data Engineering Person API Configuration
DE_PERSON_API_URL=https://your-de-person-api-url/endpoint
DE_PERSON_API_KEY=your_de_person_api_key

# VDS API Configuration
VDS_URL=https://your-vds-api-url
VDS_KEY=your_vds_bearer_token

# SAP API Configuration
SAP_URL=https://your-sap-api-url
SAP_KEY=your_sap_api_key

